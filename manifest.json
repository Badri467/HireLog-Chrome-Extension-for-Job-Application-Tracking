{
  "manifest_version": 3,
  "name": "HireLog - Job Application Tracker",
  "short_name": "HireLog",
  "version": "1.0.0",
  "key": "",
  "description": "Track job applications from career portals. One-click save with auto-fill, reminders, and Google Sheets sync.",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png"
    },
    "default_title": "HireLog — Track this job"
  },
  "background": {
    "service_worker": "background/service-worker.js"
  },

  "permissions": [
    "storage",
    "alarms",
    "notifications",
    "activeTab",
    "scripting",
    "unlimitedStorage",
    "identity"
  ],
  "oauth2": {
    "client_id": "635245352409-mgkfdsmkdnlpfokvm4u6use9t8rj9dk0.apps.googleusercontent.com",
    "scopes": [
      "https://www.googleapis.com/auth/drive.file",
      "openid",
      "email",
      "profile"
    ]
  },

  "web_accessible_resources": [
    {
      "resources": ["dashboard/dashboard.html", "icons/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
